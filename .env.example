# Copy this file to .env.local and fill in values
# .env.local is gitignored — never commit real secrets

# PostgreSQL connection string
# Local Docker: postgresql://mias:mias_dev@localhost:5432/mias_io
# Coolify sets this automatically when NEEDS_DB=true
DATABASE_URL="postgresql://mias:mias_dev@localhost:5433/mias_io"

# Next.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# CODESYS worker authentication — generate with: openssl rand -hex 32
CODESYS_API_KEY="change-me"
