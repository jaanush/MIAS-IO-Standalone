model CodesysSession {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String?   @db.Uuid @map("user_id")
  email           String    @db.VarChar(255)
  hostname        String    @db.VarChar(255)
  pluginVersion   String    @db.VarChar(50) @map("plugin_version")
  miasProjectId   Int?      @map("mias_project_id")
  projectPath     String?   @db.VarChar(500) @map("project_path")
  projectOpen     Boolean   @default(false) @map("project_open")
  pollInterval    Int       @default(10) @map("poll_interval")
  metadata        Json?                                                // project stats from plugin: { projectName, gvlCount, pouCount, dutCount }
  lastHeartbeatAt DateTime  @default(now()) @map("last_heartbeat_at")
  disconnectedAt  DateTime? @map("disconnected_at")
  createdAt       DateTime  @default(now()) @map("created_at")

