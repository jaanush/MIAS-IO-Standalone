# Deploy-hemligheter — COMMITTA ALDRIG DENNA FIL!
# Kopiera till .deploy-env och fyll i värdena.

# Azure DevOps Personal Access Token (för git push)
AZURE_PAT="din-azure-pat-här"

# Coolify API-token
COOLIFY_TOKEN="din-coolify-token-här"

# Constellation DNS (valfritt — auto-registrerar A-post vid deploy)
DNS_TOKEN="din-constellation-dns-token"

# Basic Auth (valfritt — används om BASIC_AUTH="true" i deploy.sh)
BASIC_AUTH_USER="metstech"
BASIC_AUTH_PASS="demo2026"
